PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/notemind
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production

# AI Provider API Keys (free providers first)
# Priority: Groq (free) -> Gemini (free tier) -> OpenAI (paid, optional) -> Wikipedia
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# OpenAI (optional -- paid API, only used if Groq and Gemini both fail)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# Wikipedia fallback (used when ALL AI providers fail)
FREE_NOTES_API_URL=https://en.wikipedia.org/w/api.php
USE_FREE_API_ONLY=false

# Environment
NODE_ENV=production
CORS_ORIGIN=https://your-frontend-domain.vercel.app,http://localhost:3000
